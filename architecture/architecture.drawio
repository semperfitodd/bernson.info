        <!-- LinkedIn API -->
        <mxCell id="linkedin" value="LinkedIn&#xa;API" style="shape=cloud;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1160" y="140" width="100" height="70" as="geometry"/>
        </mxCell>

        <!-- BSC Insights -->
        <mxCell id="bsc" value="BSC Insights&#xa;Blog" style="shape=cloud;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1000" y="50" width="100" height="60" as="geometry"/>
        </mxCell>

        <!-- GitHub Actions -->
        <mxCell id="gha" value="GitHub Actions&#xa;CI/CD" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="340" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- S3 TF State -->
        <mxCell id="s3tf" value="S3 Bucket&#xa;TF State" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#3F8624;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;" vertex="1" parent="1">
          <mxGeometry x="380" y="340" width="50" height="50" as="geometry"/>
        </mxCell>

        <!-- IAM OIDC -->
        <mxCell id="iam" value="IAM OIDC&#xa;Role" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.role;" vertex="1" parent="1">
          <mxGeometry x="595" y="460" width="50" height="50" as="geometry"/>
        </mxCell>

        <!-- Budget -->
        <mxCell id="budget" value="AWS Budget&#xa;Alert" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E7157B;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cost_explorer;" vertex="1" parent="1">
          <mxGeometry x="240" y="340" width="50" height="50" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" edge="1" source="user" target="r53" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="DNS" edge="1" source="r53" target="cf" parent="1" style="fontSize=10;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="OAC" edge="1" source="cf" target="s3site" parent="1" style="fontSize=10;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" edge="1" source="cf" target="acm" parent="1" style="dashed=1;fontSize=10;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" value="daily" edge="1" source="eb" target="lambda" parent="1" style="fontSize=10;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" value="scrape" edge="1" source="lambda" target="bsc" parent="1" style="fontSize=10;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7" value="articles.json" edge="1" source="lambda" target="s3site" parent="1" style="fontSize=10;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e8" value="state" edge="1" source="lambda" target="dynamo" parent="1" style="fontSize=10;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e9" value="creds" edge="1" source="lambda" target="sm" parent="1" style="dashed=1;fontSize=10;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e10" value="post" edge="1" source="lambda" target="linkedin" parent="1" style="fontSize=10;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e11" value="deploy" edge="1" source="gha" target="s3site" parent="1" style="fontSize=10;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e12" value="apply" edge="1" source="gha" target="s3tf" parent="1" style="dashed=1;fontSize=10;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e13" edge="1" source="gha" target="iam" parent="1" style="dashed=1;fontSize=10;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
